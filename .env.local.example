# Clave pública de YouTube Data API v3.
# Al ser una app 100% client-side, esta clave es visible en el navegador.
# Restríngela en Google Cloud Console mediante "HTTP referrers" para permitir
# únicamente el dominio donde publiques la aplicación.
NEXT_PUBLIC_YOUTUBE_API_KEY=

# Site key pública de Google reCAPTCHA v2 (modo "invisible").
# Antepone un reto reCAPTCHA a cada llamada real a la API para disuadir el uso
# automatizado. Es pública por diseño; créala en https://www.google.com/recaptcha/admin
# y registra el/los dominios donde se publique el sitio.
# Si se deja vacía, la verificación se omite (útil en desarrollo local).
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
